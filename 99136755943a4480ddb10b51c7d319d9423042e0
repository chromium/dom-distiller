    },
    {
      "key": {
        "uuid": "67267097_39ad8e0d",
        "filename": "java/org/chromium/distiller/DomUtil.java",
        "patchSetId": 5
      },
      "lineNbr": 458,
      "author": {
        "id": 1144344
      },
      "writtenOn": "2020-06-18T07:17:37Z",
      "side": 1,
      "message": "Thanks for pointing this out! I don\u0027t remember we\u0027ve been aware of this issue.\n\nHow exactly does querySelectorAll() fail? Always return null if |root| is not in the DOM? What if a subset of its child elements are in the DOM?",
      "parentUuid": "74f77072_ff957521",
      "revId": "99136755943a4480ddb10b51c7d319d9423042e0",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
